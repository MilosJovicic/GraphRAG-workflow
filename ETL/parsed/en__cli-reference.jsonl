{"kind": "tablerow", "id": "bedfdaeb816afbd6", "section_id": "https://code.claude.com/docs/en/cli-reference.md#cli-flags", "position": 0, "table_position": 0, "headers": ["flag", "description", "example"], "cells": ["`--add-dir`", "Add additional working directories for Claude to read and edit files. Grants file access; most `.claude/` configuration is not discovered from these directories. Validates each path exists as a directory", "`claude --add-dir ../apps ../lib`"]}
{"kind": "tablerow", "id": "276b9a3e1fe571ba", "section_id": "https://code.claude.com/docs/en/cli-reference.md#cli-flags", "position": 1, "table_position": 0, "headers": ["flag", "description", "example"], "cells": ["`--agent`", "Specify an agent for the current session (overrides the `agent` setting)", "`claude --agent my-custom-agent`"]}
{"kind": "tablerow", "id": "9f21eabadae23017", "section_id": "https://code.claude.com/docs/en/cli-reference.md#cli-flags", "position": 2, "table_position": 0, "headers": ["flag", "description", "example"], "cells": ["`--agents`", "Define custom subagents dynamically via JSON. Uses the same field names as subagent frontmatter, plus a `prompt` field for the agent's instructions", "`claude --agents '{\"reviewer\":{\"description\":\"Reviews code\",\"prompt\":\"You are a code reviewer\"}}'`"]}
{"kind": "tablerow", "id": "0b5bcc010bde3403", "section_id": "https://code.claude.com/docs/en/cli-reference.md#cli-flags", "position": 3, "table_position": 0, "headers": ["flag", "description", "example"], "cells": ["`--allow-dangerously-skip-permissions`", "Add `bypassPermissions` to the `Shift+Tab` mode cycle without starting in it. Lets you begin in a different mode like `plan` and switch to `bypassPermissions` later. See permission modes", "`claude --permission-mode plan --allow-dangerously-skip-permissions`"]}
{"kind": "tablerow", "id": "b08b04c9e4f8c439", "section_id": "https://code.claude.com/docs/en/cli-reference.md#cli-flags", "position": 4, "table_position": 0, "headers": ["flag", "description", "example"], "cells": ["`--allowedTools`", "Tools that execute without prompting for permission. See permission rule syntax for pattern matching. To restrict which tools are available, use `--tools` instead", "`\"Bash(git log *)\" \"Bash(git diff *)\" \"Read\"`"]}
{"kind": "tablerow", "id": "2a5757b24c5ab9aa", "section_id": "https://code.claude.com/docs/en/cli-reference.md#cli-flags", "position": 5, "table_position": 0, "headers": ["flag", "description", "example"], "cells": ["`--append-system-prompt`", "Append custom text to the end of the default system prompt", "`claude --append-system-prompt \"Always use TypeScript\"`"]}
