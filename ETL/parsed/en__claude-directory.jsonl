{"kind": "section", "id": "https://code.claude.com/docs/en/claude-directory.md#kept-until-you-delete-them", "page_url": "https://code.claude.com/docs/en/claude-directory.md", "anchor": "kept-until-you-delete-them", "breadcrumb": "Explore the .claude directory > Application data > Kept until you delete them", "level": 3, "position": 8, "text": "The following paths are not covered by automatic cleanup and persist indefinitely.\n\nOther small cache and lock files appear depending on which features you use and are safe to delete.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/claude-directory.md#application-data", "external_links": []}
