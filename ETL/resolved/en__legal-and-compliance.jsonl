{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#license", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "license", "breadcrumb": "Legal and compliance > Legal agreements > License", "level": 3, "position": 2, "text": "Your use of Claude Code is subject to:\n\n- Commercial Terms - for Team, Enterprise, and Claude API users\n- Consumer Terms of Service - for Free, Pro, and Max users", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#legal-agreements", "external_links": ["https://www.anthropic.com/legal/commercial-terms", "https://www.anthropic.com/legal/consumer-terms"]}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#commercial-agreements", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "commercial-agreements", "breadcrumb": "Legal and compliance > Legal agreements > Commercial agreements", "level": 3, "position": 3, "text": "Whether you're using the Claude API directly (1P) or accessing it through AWS Bedrock or Google Vertex (3P), your existing commercial agreement will apply to Claude Code usage, unless we've mutually agreed otherwise.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#legal-agreements", "external_links": []}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#legal-agreements", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "legal-agreements", "breadcrumb": "Legal and compliance > Legal agreements", "level": 2, "position": 1, "text": "", "synthesized": false, "parent_section_id": null, "external_links": []}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#healthcare-compliance-baa", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "healthcare-compliance-baa", "breadcrumb": "Legal and compliance > Compliance > Healthcare compliance (BAA)", "level": 3, "position": 5, "text": "If a customer has a Business Associate Agreement (BAA) with us, and wants to use Claude Code, the BAA will automatically extend to cover Claude Code if the customer has executed a BAA and has Zero Data Retention (ZDR) activated. The BAA will be applicable to that customer's API traffic flowing through Claude Code. ZDR is enabled on a per-organization basis, so each organization must have ZDR enabled separately to be covered under the BAA.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#compliance", "external_links": []}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#compliance", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "compliance", "breadcrumb": "Legal and compliance > Compliance", "level": 2, "position": 4, "text": "", "synthesized": false, "parent_section_id": null, "external_links": []}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#acceptable-use", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "acceptable-use", "breadcrumb": "Legal and compliance > Usage policy > Acceptable use", "level": 3, "position": 7, "text": "Claude Code usage is subject to the Anthropic Usage Policy. Advertised usage limits for Pro and Max plans assume ordinary, individual usage of Claude Code and the Agent SDK.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#usage-policy", "external_links": ["https://www.anthropic.com/legal/aup"]}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#authentication-and-credential-use", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "authentication-and-credential-use", "breadcrumb": "Legal and compliance > Usage policy > Authentication and credential use", "level": 3, "position": 8, "text": "Claude Code authenticates with Anthropic's servers using OAuth tokens or API keys. These authentication methods serve different purposes:\n\n- OAuth authentication is intended exclusively for purchasers of Claude Free, Pro, Max, Team, and Enterprise subscription plans and is designed to support ordinary use of Claude Code and other native Anthropic applications. More information about how users can authenticate with OAuth tokens can be found in Logging in to your Claude account.\n- Developers building products or services that interact with Claude's capabilities, including those using the Agent SDK, should use API key authentication through Claude Console or a supported cloud provider. Anthropic does not permit third-party developers to offer Claude.ai login or to route requests through Free, Pro, or Max plan credentials on behalf of their users.\n\nAnthropic reserves the right to take measures to enforce these restrictions and may do so without prior notice.\n\nFor questions about permitted authentication methods for your use case, please contact sales.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#usage-policy", "external_links": ["http://Claude.ai", "https://platform.claude.com/", "https://support.claude.com/en/articles/13189465-logging-in-to-your-claude-account", "https://www.anthropic.com/contact-sales?utm_source=claude_code&utm_medium=docs&utm_content=legal_compliance_contact_sales"]}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#usage-policy", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "usage-policy", "breadcrumb": "Legal and compliance > Usage policy", "level": 2, "position": 6, "text": "", "synthesized": false, "parent_section_id": null, "external_links": []}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#trust-and-safety", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "trust-and-safety", "breadcrumb": "Legal and compliance > Security and trust > Trust and safety", "level": 3, "position": 10, "text": "You can find more information in the Anthropic Trust Center and Transparency Hub.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#security-and-trust", "external_links": ["https://trust.anthropic.com", "https://www.anthropic.com/transparency"]}
{"kind": "section", "id": "https://code.claude.com/docs/en/legal-and-compliance.md#security-vulnerability-reporting", "page_url": "https://code.claude.com/docs/en/legal-and-compliance.md", "anchor": "security-vulnerability-reporting", "breadcrumb": "Legal and compliance > Security and trust > Security vulnerability reporting", "level": 3, "position": 11, "text": "Anthropic manages our security program through HackerOne. Use this form to report vulnerabilities.\n\n---\n\n© Anthropic PBC. All rights reserved. Use is subject to applicable Anthropic Terms of Service.", "synthesized": false, "parent_section_id": "https://code.claude.com/docs/en/legal-and-compliance.md#security-and-trust", "external_links": ["https://hackerone.com/4f1f16ba-10d3-4d09-9ecc-c721aad90f24/embedded_submissions/new"]}
