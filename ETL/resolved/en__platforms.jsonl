{"kind": "section", "id": "https://code.claude.com/docs/en/platforms.md#connect-your-tools", "page_url": "https://code.claude.com/docs/en/platforms.md", "anchor": "connect-your-tools", "breadcrumb": "Platforms and integrations > Connect your tools", "level": 2, "position": 2, "text": "Integrations let Claude work with services outside your codebase.\n\nFor integrations not listed here, MCP servers and connectors let you connect almost anything: Linear, Notion, Google Drive, or your own internal APIs.", "synthesized": false, "parent_section_id": null, "external_links": []}
